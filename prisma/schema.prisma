// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  lastName  String
  firstName String
  image     String?
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id Int @id @default(autoincrement())

  // Campos en español
  title_es   String
  content_es String?
  slug_es    String  @unique

  // Campos en inglés
  title_en   String
  content_en String?
  slug_en    String  @unique

  published     Boolean     @default(false)
  authorId      String
  author        User        @relation(fields: [authorId], references: [id])
  image         String
  video         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  categoryId    Int
  category      Category    @relation(fields: [categoryId], references: [id])
  subcategoryId Int
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id])

  // Recipe structured data (SEO rich results)
  recipeIngredients  String[]
  recipeInstructions String[]
  recipeYield        String?
  recipePrepTime     String?
  recipeCookTime     String?

  // Índices para mejorar el rendimiento
  @@index([slug_es])
  @@index([slug_en])
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  posts         Post[]
  subcategories Subcategory[]
}

model Subcategory {
  id         Int      @id @default(autoincrement())
  name       String
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int
  posts      Post[]
}

model Purchase {
  id                  String  @id @default(cuid())
  stripeSessionId     String  @unique
  stripePaymentIntent String? @unique
  customerEmail       String
  customerName        String?
  amount              Int // Monto en centavos
  currency            String  @default("usd")

  // Información del producto
  productName String
  productType String // "ebook", "course", etc.
  s3Key       String // Ubicación del archivo en S3

  // Status
  is_paid   Boolean @default(false)
  emailSent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeSessionId])
  @@index([customerEmail])
}

model PaymentEvent {
  id                  String   @id @default(cuid())
  stripeEventId       String?  @unique
  stripeLivemode      Boolean?
  eventType           String
  stripePaymentIntent String?
  stripeChargeId      String?
  stripeSessionId     String?
  customerEmail       String?
  customerName        String?
  amount              Int?
  currency            String?
  productName         String?
  productType         String?
  status              String?
  failureCode         String?
  failureMessage      String?
  rawPayload          Json?
  createdAt           DateTime @default(now())

  @@index([eventType])
  @@index([stripePaymentIntent])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([stripeLivemode, createdAt])
}

model Book {
  id                 String   @id @default(cuid())
  slug_en            String   @unique
  slug_es            String   @unique
  title_en           String
  title_es           String
  subtitle_en        String
  subtitle_es        String
  author             String
  price              Int
  originalPrice      Int?
  discount           Int?
  coverImage_en      String
  coverImage_es      String
  s3Key_en           String
  s3Key_es           String
  description_en     String
  description_es     String
  features_en        String[]
  features_es        String[]
  pages              Int
  format_en          String
  format_es          String
  language_en        String
  language_es        String
  isbn               String?
  rating             Float?
  reviewCount        Int?
  featured_review_en String?
  featured_review_es String?
  reviewerName       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([author])
}

model NewsletterSignup {
  id        String    @id @default(cuid())
  email     String    @unique
  locale    String?
  source    String?
  sourceUrl String?
  handledAt DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdAt])
}
